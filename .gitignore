# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# build output
/dist

# interactive demo bundle — built from src/ by the deploy workflow (build:demo),
# never committed
/docs/demo

# rust / tauri
/src-tauri/target

# npm (project uses pnpm)
package-lock.json

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local notes (kept out of repo)
CLAUDE.md
IDEAS.md
